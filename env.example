# Discord Developer Portal থেকে পাওয়া bot token
DISCORD_TOKEN= give bot token

# https://openrouter.ai/keys থেকে পাওয়া API key (সাইন-আপে কোনো কার্ড লাগে না)
OPENROUTER_API_KEY= give api

# ঐচ্ছিক সেটিংস (না দিলে default value ব্যবহার হবে)
BOT_NAME=Miku

# OpenRouter এর যেকোনো ":free" model ব্যবহার করা যাবে, লিস্ট: https://openrouter.ai/models?max_price=0
# main.py এর FALLBACK_MODELS লিস্টে verified live model দিয়ে auto fallback করা আছে
CHAT_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free
STATUS_TEXT=Waiting for u 💭
MAX_HISTORY_TURNS=20
