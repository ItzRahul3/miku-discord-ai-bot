# Discord Developer Portal থেকে পাওয়া bot token
DISCORD_TOKEN=your_discord_bot_token_here

# Google AI Studio (https://aistudio.google.com/apikey) থেকে পাওয়া Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# ঐচ্ছিক সেটিংস (না দিলে default value ব্যবহার হবে)
BOT_NAME=Miku
CHAT_MODEL_NAME=gemini-2.0-flash
IMAGE_MODEL_NAME=gemini-2.0-flash-preview-image-generation
MAX_HISTORY_TURNS=20
STATUS_TEXT=Waiting for u 💭
